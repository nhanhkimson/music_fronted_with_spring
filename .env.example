# Copy to `.env.local` in this folder.

# --- Optional: use a different host for POST /api/download (e.g. Spring on Fly.io) ---
# Same-origin /api/download uses yt-dlp on the server (see YTDLP_PATH). On Vercel, point here instead.
# NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Optional: full path to yt-dlp when `next dev` / Node cannot find it on PATH (e.g. IntelliJ on macOS) ---
# YTDLP_PATH=/opt/homebrew/bin/yt-dlp

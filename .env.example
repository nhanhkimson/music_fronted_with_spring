# Copy to `.env.local` in this folder.

# --- Local dev: built-in Next API (no Spring) ---
# Leave NEXT_PUBLIC_API_URL unset. Requires yt-dlp + ffmpeg on this machine.

# --- Local dev: Spring backend instead ---
# NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Vercel / production UI ---
# Required: deployed API base URL (Fly, VPS, Spring, etc.). No trailing slash.
# NEXT_PUBLIC_API_URL=https://your-api.fly.dev

# --- Server only (local Next /api/download) — if PATH has no yt-dlp
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp

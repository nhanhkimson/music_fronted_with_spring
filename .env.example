# Optional overrides (default Vercel deploy needs none of this).

# Delegate POST /api/download to another host (e.g. Spring on Fly for MP3 + ffmpeg).
# NEXT_PUBLIC_API_URL=https://your-api.fly.dev

# Local: if `yt-dlp` is not on PATH (e.g. IntelliJ).
# YTDLP_PATH=/opt/homebrew/bin/yt-dlp

# YouTube may block datacenter IPs ("Sign in to confirm you're not a bot"). Optional Netscape cookies file (base64):
# macOS: base64 -i cookies.txt | tr -d '\n'
# YTDLP_COOKIES_B64=...

# Copy to `.env.local` in this folder.

# --- API target ---
# Leave unset or empty to use the built-in Next.js API (POST /api/download).
# Requires yt-dlp + ffmpeg on the machine running `next dev` / `next start`.
# To use the Spring Boot backend instead:
# NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Server only (Next API route) — optional override when yt-dlp is not on PATH
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
